<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_stock_picking_form_gestion_utiles_escolares" model="ir.ui.view">
        <field name="name">stock.picking.form.gestion.utiles.escolares</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Control de útiles escolares">
                    <group>
                        <group string="Relación escolar">
                            <field name="estudiante_id"/>
                            <field name="apoderado_entrega_id"/>
                        </group>
                        <group string="Estado de recepción">
                            <field name="estado_entrega_utiles"/>
                            <field name="tipo_operacion_escolar"/>
                            <field name="utiles_personales_verificados"/>
                        </group>
                    </group>
                    <group>
                        <field name="observacion_faltantes"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
